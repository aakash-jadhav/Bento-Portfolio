# Local dev: leave unset — the app calls /api/... and Vite proxies to your backend (e.g. port 4000).
#
# Production (Netlify, etc.) with API on Render: REQUIRED — or the live site cannot load/save DB content
# and may show defaults until you set this and rebuild:
# VITE_API_URL=https://your-service.onrender.com
